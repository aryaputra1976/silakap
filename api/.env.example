# ============================================================
# DATABASE - credentials dari hPanel > Databases > MySQL
# ============================================================
DATABASE_URL="mysql://DB_USER:DB_PASS@localhost:3306/DB_NAME"
# Opsional jika tidak memakai query string DATABASE_URL; dipakai Prisma client runtime.
DB_POOL_LIMIT=20
DB_POOL_TIMEOUT=30

# ============================================================
# JWT - generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET="isi-random-string-min-64-karakter"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="isi-random-string-lain-min-64-karakter"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# APP
# ============================================================
NODE_ENV="production"
PORT=3000
API_PREFIX="/api/v1"
APP_URL="https://yourdomain.com"

# ============================================================
# SECURITY
# ============================================================
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=30
PASSWORD_HISTORY_COUNT=5
PASSWORD_EXPIRY_DAYS=90
MAX_SESSIONS_PER_USER=3
INACTIVE_ACCOUNT_DAYS=90
MAX_FILE_SIZE_MB=5

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# ============================================================
# UPLOAD - path permanen di Hostinger/cPanel, di luar public_html
# ============================================================
UPLOAD_DIR="/home/username/uploads"

# ============================================================
# BACKUP - path permanen di Hostinger/cPanel, di luar public_html
# ============================================================
BACKUP_DIR="/home/username/backups"
BACKUP_RETENTION_FILES=7
MYSQLDUMP_BIN="mysqldump"

# ============================================================
# CRON - secret untuk autentikasi endpoint cron dari cPanel
# ============================================================
CRON_SECRET="isi-random-string-min-32-karakter"

# ============================================================
# EMAIL - dari hPanel > Email Accounts
# ============================================================
EMAIL_ENABLED=true
SMTP_HOST="mail.yourdomain.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="email-password-anda"
SMTP_FROM="SILAKAP <noreply@yourdomain.com>"

# ============================================================
# WHATSAPP - opsional, isi jika memakai gateway internal/vendor
# ============================================================
WHATSAPP_ENABLED=false
WHATSAPP_WEBHOOK_URL=""
WHATSAPP_TOKEN=""

# ============================================================
# MONITORING - buat project di https://sentry.io lalu salin DSN
# ============================================================
SENTRY_DSN=""

# ============================================================
# AI - default local tetap berjalan tanpa API eksternal
# ============================================================
AI_PROVIDER="local"
AI_API_KEY=""
AI_BASE_URL="https://api.openai.com/v1/chat/completions"
AI_MODEL=""
AI_TIMEOUT_MS=30000
AI_SHARE_SENSITIVE_DATA=false
